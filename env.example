# ── Anthropic ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Twilio (SMS) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+17804440000        # Your Twilio number (Edmonton area code)

# ── Google Calendar ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token
GOOGLE_CALENDAR_ID=primary              # or specific calendar ID

# ── Business Config ────────────────────────────────────────────
BUSINESS_NAME="Apex Heating & Plumbing"
BUSINESS_PHONE=+17804441234
BUSINESS_TYPE=hvac                      # hvac | plumbing | electrical | construction
OWNER_EMAIL=owner@apexheating.ca
OWNER_PHONE=+17804441234

# ── Booking Windows (Edmonton business hours) ──────────────────
BOOKING_START_HOUR=8                    # 8am
BOOKING_END_HOUR=17                     # 5pm
BOOKING_SLOT_MINUTES=120                # 2hr service windows
EMERGENCY_SURCHARGE=150                 # After-hours surcharge

# ── CRM (optional) ────────────────────────────────────────────
# SERVICETITAN_TENANT_ID=your_tenant_id
# SERVICETITAN_CLIENT_ID=your_client_id
# SERVICETITAN_CLIENT_SECRET=your_secret

# ── Server ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
